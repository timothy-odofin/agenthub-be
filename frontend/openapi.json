          },
          "progress_percentage": {
            "description": "Signup completion percentage (0-100)",
            "title": "Progress Percentage",
            "type": "integer"
          },
          "refresh_token": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "JWT refresh token if signup complete",
            "title": "Refresh Token"
          },
          "session_id": {
            "description": "Session ID for tracking conversation",
            "title": "Session Id",
            "type": "string"
          },
          "success": {
            "description": "Whether the current step was successful",
            "title": "Success",
            "type": "boolean"
          },
          "token_type": {
            "default": "bearer",
            "description": "Token type",
            "title": "Token Type",
            "type": "string"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Created user ID if signup complete",
            "title": "User Id"
          },
          "validation_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Validation error message if any",
            "title": "Validation Error"
          }
        },
        "required": [
          "success",
          "message",
          "next_step",
          "session_id",
          "progress_percentage",
          "fields_remaining"
        ],
        "title": "ConversationalSignupResponse",
        "type": "object"
