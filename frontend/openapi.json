      "ConversationalSignupRequest": {
        "description": "Request schema for conversational signup with Redis session management.\n\nClient sends 3 fields:\n1. message: User's input (required)\n2. session_id: Tracking ID (null for START, required for all other steps)\n3. current_step: Current step (null for START, required for all other steps)\n\nAll validated data is stored server-side in Redis.\nThis prevents password exposure and ensures data integrity.\n\nFlow:\n- First request: {\"message\": \"\", \"session_id\": null, \"current_step\": \"start\"}\n- Server returns: session_id in response (e.g., \"abc-123\")\n- Subsequent requests: {\"message\": \"user input\", \"session_id\": \"abc-123\", \"current_step\": \"email\"}",
        "examples": [
          {
            "current_step": "start",
            "description": "Step 1: START - Initialize signup (session_id is null)",
            "message": ""
          },
          {
            "current_step": "email",
            "description": "Step 2: EMAIL - Provide email (session_id from server response)",
            "message": "john@example.com",
            "session_id": "abc-123-uuid-from-server"
          },
          {
            "current_step": "username",
            "description": "Step 3: USERNAME - Provide username (same session_id)",
            "message": "johndoe",
            "session_id": "abc-123-uuid-from-server"
          },
          {
            "current_step": "password",
            "description": "Step 4: PASSWORD - Provide password (same session_id)",
            "message": "SecurePass123",
            "session_id": "abc-123-uuid-from-server"
          },
          {
            "current_step": "firstname",
            "description": "Step 5: FIRSTNAME - Provide first name (same session_id)",
            "message": "John",
            "session_id": "abc-123-uuid-from-server"
          },
          {
            "current_step": "lastname",
            "description": "Step 6: LASTNAME - Provide last name (same session_id)",
            "message": "Doe",
            "session_id": "abc-123-uuid-from-server"
          }
        ],
        "properties": {
          "current_step": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SignupStep"
              },
              {
                "type": "null"
              }
            ],
            "description": "Current step (MUST match next_step from previous response, null only for START)",
            "examples": [
              "email"
            ]
          },
          "message": {
            "description": "User's message/input for current step",
            "examples": [
              "john@example.com"
            ],
            "title": "Message",
            "type": "string"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Session ID from server response (null only for START step)",
            "examples": [
              "abc-123"
            ],
            "title": "Session Id"
          }
        },
        "required": [
          "message"
        ],
        "title": "ConversationalSignupRequest",
        "type": "object"
      },
      "ConversationalSignupResponse": {
        "description": "Response schema for conversational signup.",
        "properties": {
          "access_token": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "JWT access token if signup complete",
            "title": "Access Token"
          },
          "fields_remaining": {
            "description": "Number of fields still needed",
            "title": "Fields Remaining",
            "type": "integer"
          },
          "is_valid": {
            "default": true,
            "description": "Whether current input is valid",
            "title": "Is Valid",
            "type": "boolean"
          },
          "message": {
            "description": "Bot's response message to user",
