<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.agentdesk.controller.ArtifactPanelController"
            styleClass="artifact-panel">

    <!-- Header -->
    <top>
        <HBox styleClass="artifact-header" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>

            <Label fx:id="artifactTypeIcon" styleClass="artifact-type-icon"/>
            <VBox spacing="1" HBox.hgrow="ALWAYS">
                <Label fx:id="artifactTitle" text="Artifact" styleClass="artifact-title"/>
                <Label fx:id="artifactSubtitle" text="" styleClass="artifact-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeBtn" styleClass="artifact-close-btn" onAction="#handleClose">
                <tooltip><Tooltip text="Close panel"/></tooltip>
            </Button>
        </HBox>
    </top>

    <!-- Content area: swap between views -->
    <center>
        <StackPane fx:id="contentStack" styleClass="artifact-content">

            <!-- Code view -->
            <ScrollPane fx:id="codeScrollPane" styleClass="artifact-code-scroll"
                        fitToWidth="true" fitToHeight="true"
                        visible="false" managed="false">
                <TextArea fx:id="codeArea" styleClass="artifact-code-area"
                          editable="false" wrapText="true"/>
            </ScrollPane>

            <!-- HTML / WebView -->
            <WebView fx:id="webView" visible="false" managed="false"/>

            <!-- Document text view -->
            <ScrollPane fx:id="docScrollPane" styleClass="artifact-doc-scroll"
                        fitToWidth="true" fitToHeight="true"
                        visible="false" managed="false">
                <VBox fx:id="docContainer" styleClass="artifact-doc-container" spacing="8">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label fx:id="docContent" styleClass="artifact-doc-text" wrapText="true"/>
                </VBox>
            </ScrollPane>

            <!-- Download card -->
            <VBox fx:id="downloadCard" styleClass="artifact-download-card"
                  alignment="CENTER" spacing="16"
                  visible="false" managed="false">
                <Label fx:id="downloadIcon" styleClass="artifact-download-icon"/>
                <Label fx:id="downloadFilename" styleClass="artifact-download-filename"/>
                <Label fx:id="downloadSize" styleClass="artifact-download-size"/>
                <Button fx:id="downloadBtn" text="Download" styleClass="artifact-download-btn"
                        onAction="#handleDownload"/>
            </VBox>
        </StackPane>
    </center>

    <!-- Footer: action buttons -->
    <bottom>
        <HBox fx:id="footerActions" styleClass="artifact-footer" alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="10" right="16" bottom="14" left="16"/></padding>
            <Button fx:id="copyArtifactBtn" styleClass="artifact-action-btn" onAction="#handleCopy">
                <tooltip><Tooltip text="Copy content"/></tooltip>
            </Button>
            <Button fx:id="downloadArtifactBtn" styleClass="artifact-action-btn" onAction="#handleDownload">
                <tooltip><Tooltip text="Download"/></tooltip>
            </Button>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="footerStatus" styleClass="artifact-footer-status"/>
        </HBox>
    </bottom>
</BorderPane>
